# =============================================================
# 投资 Pipeline 管理系统 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# =============================================================

# ── 路径 ──────────────────────────────────────────────────────
# 项目根目录（包含 Excel 数据文件、reporter/ 等）
# 默认 = 当前目录，通常无需修改
# REPORT_DIR=/path/to/project

# Skill 文件目录（AI 分析框架 .skill 压缩包存放位置）
# 如果不使用 AI 周报生成功能，可以不设置
# SKILL_ROOT=/path/to/skills

# ── 服务 ──────────────────────────────────────────────────────
APP_HOST=127.0.0.1
PORT=8766
APP_DEBUG=true

# ── 数据库 ────────────────────────────────────────────────────
# 开发：SQLite（默认，无需额外安装）
# 生产：PostgreSQL（需先 docker-compose up -d db）
# DATABASE_URL=sqlite:///pipeline_saas.db
# 生产示例:
# DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/pipeline_saas

# ── JWT 认证 ──────────────────────────────────────────────────
# 签名密钥（生产环境请使用随机字符串！）
# JWT_SECRET=change-me-to-a-random-string-32-bytes
# 签名算法
# JWT_ALGORITHM=HS256
# Access token 过期时间（分钟），默认 60
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token 过期时间（天），默认 30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── 安全 ──────────────────────────────────────────────────────
# Flask session 密钥（生产环境请使用随机字符串！）
FLASK_SECRET=change-me-to-a-random-string

# 登录密码（不设置则密码登录禁用；本地开发可设置为简单密码）
PORTAL_PASSWORD=changeme

# 连续登录失败后的冷却时间（秒）
LOGIN_COOLDOWN_SECONDS=20

# 上传文件大小上限（MB）
MAX_CONTENT_LENGTH_MB=25

# ── 速率限制 ──────────────────────────────────────────────────
# 全局限制（所有接口）
# RATE_LIMIT_GLOBAL=200 per minute
# 认证接口限制（防暴力破解）
# RATE_LIMIT_AUTH=10 per minute
# AI 生成限制（控制 API 费用）
# RATE_LIMIT_AI=30 per minute

# ── AI ────────────────────────────────────────────────────────
# DeepSeek API（AI 周报生成）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Tavily 搜索 API（检索项目公开信息，可选）
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API（AI 摘要生成，可选）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 多租户 ────────────────────────────────────────────────────
# 默认租户名称（开发环境自动创建）
# DEFAULT_TENANT_NAME=语涵

# ── 数据 ──────────────────────────────────────────────────────
# Excel 备份保留数量
MAX_BACKUPS=30

# 数据治理：长期无更新阈值（周数）
STALE_WEEKS_THRESHOLD=8
